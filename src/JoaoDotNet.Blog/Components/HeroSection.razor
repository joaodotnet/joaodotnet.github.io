<section class="hero">
    <div class="hero-content">
        <p class="hero-kicker">@Kicker</p>
        <h1>@Title</h1>
        <p class="hero-subtitle">@Subtitle</p>
        <div class="hero-actions">
            <a class="btn btn-primary" href="@PrimaryHref">@PrimaryText</a>
            <a class="btn btn-ghost" href="@SecondaryHref">@SecondaryText</a>
        </div>
    </div>
    <div class="hero-visual">
        <div class="hero-card">
            @if (!string.IsNullOrEmpty(VisualImageSrc))
            {
                <img src="@VisualImageSrc" 
                     alt="@VisualImageAlt" 
                     class="hero-image" 
                     width="@VisualImageWidth"
                     height="@VisualImageHeight"
                     fetchpriority="high"
                     decoding="async"
                     onError="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                <div style="display:none">
                    <p class="hero-card-title">@CardTitle</p>
                    <p class="hero-card-body">@CardBody</p>
                </div>
            }
            else
            {
                <p class="hero-card-title">@CardTitle</p>
                <p class="hero-card-body">@CardBody</p>
            }
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired]
    public string Kicker { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Subtitle { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string PrimaryText { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string PrimaryHref { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string SecondaryText { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string SecondaryHref { get; set; } = string.Empty;

    [Parameter]
    public string? CardTitle { get; set; }

    [Parameter]
    public string? CardBody { get; set; }

    [Parameter]
    public string? VisualImageSrc { get; set; }

    [Parameter]
    public string VisualImageAlt { get; set; } = "Profile Image";

    [Parameter]
    public int? VisualImageWidth { get; set; }

    [Parameter]
    public int? VisualImageHeight { get; set; }
}
