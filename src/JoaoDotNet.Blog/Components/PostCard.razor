@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResources> Localizer

<article class="post-card">
    <div class="post-card-meta">
        <span class="post-date">@Post.Date.ToString("D")</span>
        <span class="post-read">@Post.ReadTimeMinutes @Localizer["ReadTime"]</span>
    </div>
    <h3 class="post-title">@Post.Title</h3>
    <p class="post-summary">@Post.Summary</p>
    <div class="post-tags">
        @foreach (var tag in Post.Tags)
        {
            <TagBadge Text="@tag" />
        }
    </div>
    <a class="post-link" href="post/@Post.Slug">@Localizer["ReadMore"]</a>
</article>

@code {
    [Parameter, EditorRequired]
    public PostMetadata Post { get; set; } = new();
}
