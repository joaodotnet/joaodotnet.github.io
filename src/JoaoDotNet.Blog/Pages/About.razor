@page "/about"
@using JoaoDotNet.Blog.Models
@inject Microsoft.Extensions.Localization.IStringLocalizer<About> Localizer
@inject JoaoDotNet.Blog.Services.ExperienceService ExperienceService
@inject JoaoDotNet.Blog.Services.CertificationService CertificationService

<PageTitle>@Localizer["PageTitle"]</PageTitle>

<section class="about-hero">
    <div class="about-copy">
        <p class="hero-kicker">@Localizer["Hero_Kicker"]</p>
        <h1>@Localizer["Hero_Title"]</h1>
        <div class="about-profile-visual mobile-visual">
            <img src="images/profile.jpg" alt="@Localizer["Hero_Title"]" class="about-profile-image" width="400" height="400" fetchpriority="high" decoding="async" />
        </div>
        <p class="hero-subtitle">@Localizer["Hero_Subtitle"]</p>
        <SocialLinks />
    </div>
    <div class="about-profile-visual desktop-visual">
        <img src="images/profile.jpg" alt="@Localizer["Hero_Title"]" class="about-profile-image" width="400" height="400" fetchpriority="high" decoding="async" />
    </div>
    <div class="about-card">
        <p>@((MarkupString)Localizer["Bio_Intro"].Value)</p>
    </div>
</section>

<section class="section">
    <div class="section-header">
        <h2>@Localizer["Section_Skills"]</h2>
    </div>
    <div class="chip-grid">
        @foreach (var skill in skills)
        {
            <span class="chip">@skill</span>
        }
    </div>
</section>

<section class="section">
    <div class="section-header">
        <h2>@Localizer["Section_Certifications"]</h2>
    </div>
    <div class="certification-groups">
        @foreach (var group in certificationGroups)
        {
            <div class="certification-group">
                <h3 class="certification-group-title">@group.Title</h3>
                <div class="certifications-grid">
                    @foreach (var certification in group.Items)
                    {
                        <div class="certification-card">
                            <img src="@certification.ImageUrl" alt="@certification.Name" class="certification-badge" />
                            <h4 class="certification-name">@certification.Name</h4>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>

<section class="section">
    <div class="section-header">
        <h2>@Localizer["Section_Experience"]</h2>
    </div>
    <ExperienceTimeline Items="@timelineItems" />
</section>

<section class="section">
    <div class="section-header">
        <h2>@Localizer["Section_Education"]</h2>
    </div>
    <div class="info-card">
        <h3>@Localizer["Education_Title"]</h3>
        <div class="education-meta-grid">
            <div class="education-meta-item">
                <h4>@Localizer["Education_Dates_Label"]</h4>
                <p>@Localizer["Education_Dates"]</p>
            </div>
            <div class="education-meta-item">
                <h4>@Localizer["Education_School_Label"]</h4>
                <p>@Localizer["Education_School"]</p>
            </div>
        </div>
        <p>@Localizer["Education_Body"]</p>
    </div>
</section>

@code {
    private static readonly string[] certificationCategoryOrder = ["Specialty", "Expert", "Associate", "Fundamentals", "AppliedSkills"];

    private IReadOnlyList<TimelineEntry> timelineItems = Array.Empty<TimelineEntry>();
    private IReadOnlyList<string> skills = Array.Empty<string>();
    private IReadOnlyList<Certification> certifications = Array.Empty<Certification>();
    private IReadOnlyList<CertificationGroup> certificationGroups = Array.Empty<CertificationGroup>();

    protected override async Task OnInitializedAsync()
    {
        timelineItems = await ExperienceService.GetExperiencesAsync();
        certifications = await CertificationService.GetCertificationsAsync();
        certificationGroups = BuildCertificationGroups(certifications);

        skills = new List<string>
        {
            Localizer["Skill_1"],
            Localizer["Skill_2"],
            Localizer["Skill_10"],
            Localizer["Skill_3"],
            Localizer["Skill_4"],
            Localizer["Skill_5"],
            Localizer["Skill_6"],
            Localizer["Skill_7"],
            Localizer["Skill_8"],
            Localizer["Skill_9"]
        };
    }

    private IReadOnlyList<CertificationGroup> BuildCertificationGroups(IReadOnlyList<Certification> items)
    {
        return certificationCategoryOrder
            .Select(category =>
            {
                var groupedItems = items
                    .Where(certification => string.Equals(ResolveCertificationCategory(certification), category, StringComparison.OrdinalIgnoreCase))
                    .OrderBy(certification => certification.Order ?? int.MaxValue)
                    .ThenBy(certification => certification.Name, StringComparer.CurrentCultureIgnoreCase)
                    .ToList();

                return new CertificationGroup(
                    category,
                    Localizer[$"CertificationGroup_{category}"],
                    groupedItems);
            })
            .Where(group => group.Items.Count > 0)
            .ToList();
    }

    private static string ResolveCertificationCategory(Certification certification)
    {
        if (!string.IsNullOrWhiteSpace(certification.Category))
        {
            return certification.Category;
        }

        if (certification.Name.Contains("Applied Skills", StringComparison.OrdinalIgnoreCase))
        {
            return "AppliedSkills";
        }

        if (certification.Name.Contains("Specialty", StringComparison.OrdinalIgnoreCase))
        {
            return "Specialty";
        }

        if (certification.Name.Contains("Expert", StringComparison.OrdinalIgnoreCase))
        {
            return "Expert";
        }

        if (certification.Name.Contains("Fundamentals", StringComparison.OrdinalIgnoreCase))
        {
            return "Fundamentals";
        }

        return "Associate";
    }

    private sealed record CertificationGroup(string Category, string Title, IReadOnlyList<Certification> Items);
}
